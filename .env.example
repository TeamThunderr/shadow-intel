# Azure AI Foundry (Foundry IQ)
AZURE_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_FOUNDRY_API_KEY=your_key_here
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o

# Microsoft Fabric (Fabric IQ)
FABRIC_WORKSPACE_ID=your_workspace_id
FABRIC_LAKEHOUSE_ID=your_lakehouse_id
FABRIC_CLIENT_ID=your_client_id
FABRIC_CLIENT_SECRET=your_client_secret
FABRIC_TENANT_ID=your_tenant_id

# Microsoft Graph API (Work IQ — Teams + Outlook)
GRAPH_CLIENT_ID=your_client_id
GRAPH_CLIENT_SECRET=your_client_secret
GRAPH_TENANT_ID=your_tenant_id
GRAPH_TEAMS_CHANNEL_ID=your_channel_id
GRAPH_TEAMS_TEAM_ID=your_team_id
GRAPH_SENDER_EMAIL=

# OpenSanctions
OPENSANCTIONS_API_KEY=your_key_here

# OpenCorporates
OPENCORPORATES_API_KEY=your_key_here

# Companies House (UK)
COMPANIES_HOUSE_API_KEY=your_key_here

# OCCRP Aleph
OCCRP_API_KEY=your_key_here

# Blockchain Explorers
ETHERSCAN_API_KEY=your_key_here

# News / GDELT (no key needed for GDELT)
NEWS_API_KEY=your_key_here

# App
APP_ENV=development
APP_PORT=8000
CONFIDENCE_THRESHOLD=0.80
